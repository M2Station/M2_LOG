{
  "_comment": "UEFI log highlight rules. Edit this file to add/adjust highlighting. Each rule: name, level (error|warn|info|version|boot|membucket), pattern (JavaScript regex source, case-insensitive). Whole-line tint follows the highest level matched on that line.",
  "rules": [
    {
      "name": "error",
      "level": "error",
      "pattern": "\\b(?:error|err|fail(?:ed|ure)?|fatal|panic|exception|assert(?:ion)?|abort(?:ed)?|halt|hang|bugcheck|unexpected|invalid|corrupt(?:ed)?)\\b"
    },
    {
      "name": "efi-error-status",
      "level": "error",
      "pattern": "EFI_[A-Z0-9_]*?(?:ERROR|NOT_FOUND|UNSUPPORTED|TIMEOUT|ABORTED|SECURITY_VIOLATION|DEVICE_ERROR|ACCESS_DENIED)"
    },
    {
      "name": "warning",
      "level": "warn",
      "pattern": "\\b(?:warn(?:ing)?|timeout|timed?\\s*out|retry|retries|retrying|skip(?:ped)?|deprecated)\\b"
    },
    {
      "name": "bios-version",
      "level": "version",
      "pattern": "BIOS\\s+version\\s*:.*"
    },
    {
      "name": "commit-sha",
      "level": "version",
      "pattern": "Commit\\s+SHA\\s*:.*"
    },
    {
      "name": "BOOT_MODE",
      "level": "bootmode",
      "pattern": "System\\s+boot\\s+mode\\s*:.*"
    },
    {
      "name": "boot-fsp-t-car-init",
      "level": "boot",
      "pattern": "FSP-T\\s*:\\s*CAR\\s+Init"
    },
    {
      "name": "boot-exit-boot-services",
      "level": "boot",
      "pattern": "EBS\\s+completed\\s+successfully"
    },
    {
      "name": "Capsule",
      "level": "capsule",
      "pattern": "(?:Attempting\\s+to\\s+apply\\s+Capsule|Fmp->SetImage).*"
    },
    {
      "name": "Screen Notifications",
      "level": "screennotif",
      "pattern": "On\\s+Screen\\s+Notifications\\s*:.*"
    },
    {
      "name": "UEFI Runtime Mode",
      "level": "runtimemode",
      "pattern": "UEFI\\s+Runtime\\s+Mode\\s*:.*"
    },
    {
      "name": "membucket-header",
      "level": "membucket",
      "pattern": "Memory\\s+Previous\\s+Current\\s+Minimum\\s+Next"
    }
  ]
}

{
  "_comment": "QC UEFI (Patina) log highlight rules. Edit this file to add/adjust highlighting. Each rule: name, level (error|warn|info|version|hwinfo, or a custom level), pattern (JavaScript regex source, case-insensitive). Whole-line tint follows the highest level matched on that line.",
  "rules": [
    {
      "name": "error",
      "level": "error",
      "pattern": "\\b(?:error|err|fail(?:ed|ure)?|fatal|panic|exception|assert(?:ion)?|abort(?:ed)?|halt|hang|bugcheck|unexpected|invalid|corrupt(?:ed)?)\\b"
    },
    {
      "name": "warning",
      "level": "warn",
      "pattern": "\\b(?:warn(?:ing)?|timeout|timed?\\s*out|retry|retries|retrying|skip(?:ped)?|deprecated)\\b"
    },
    {
      "name": "i2c-transfer-failed",
      "level": "error",
      "pattern": "iStatus\\s*=\\s*0x[0-9a-f]+"
    },
    {
      "name": "fru",
      "level": "fru",
      "pattern": "TDM\\s+Replacement\\s+Mode\\s+(?:not\\s+)?requested|New\\s+Display\\s+Module\\s+detected|Unlocking\\s+Cal\\s+data\\s+storage|SerialNumUpdateRequested\\s*:\\s*\\d|Motherboard\\s+Serial\\s+Number\\s*:"
    },
    {
      "name": "version",
      "level": "version",
      "pattern": "(?:Bootchain\\s+version|SAM\\s+version|UEFI\\s+Runtime\\s+Mode|Commit\\s+Hash)\\s*:.*"
    },
    {
      "name": "patina-version",
      "level": "version",
      "pattern": "Starting\\s+Patina\\s+with\\s+\\S+\\s+[\\d.]+"
    },
    {
      "name": "soc-serial-number",
      "level": "socsn",
      "pattern": "Serial\\s+Number\\s*@\\s*0x[0-9A-Fa-f]+\\s*=\\s*0x[0-9A-Fa-f]+"
    },
    {
      "name": "hwinfo",
      "level": "hwinfo",
      "pattern": "(?:Program\\s+ID|SKU\\s+ID|Memory\\s+ID|Build\\s+ID|SoC\\s+Version|SoC\\s+Cores|SoC\\s+Fuse|Tdm\\s+Board\\s+ID|Storage\\s+Type)\\s*:.*"
    },
    {
      "name": "spinor-vendor-id",
      "level": "hwinfo",
      "pattern": "Spinor\\(9F\\)\\s*:.*"
    },
    {
      "name": "nvram-dump",
      "level": "nvram",
      "pattern": "\\[DebugDumpAllUefiVariables\\].*|(?:NV|BS|RT)[+A-Z]*\\s+'[^']+'\\s+DataSize\\s*=\\s*0x[0-9A-Fa-f]+"
    },
    {
      "name": "nvram-varlist",
      "level": "nvram",
      "pattern": "==== TestPointDumpVariable.*|Variable List:|Name=L\"[^\"]*\"\\s+Guid=.*Attr=.*"
    },
    {
      "name": "gpio-config",
      "level": "gpio",
      "pattern": "\\[ConfigAndSetGpios\\].*|GPIO_\\d+\\s+FUNCTION:.*"
    },
    {
      "name": "gpio-platconf",
      "level": "gpio",
      "pattern": "\\[PlatConfSocGpioPrint\\].*|\\[GPIO No\\.\\s*\\d+\\].*"
    },
    {
      "name": "uefi-perf",
      "level": "perf",
      "pattern": "FirmwareBootPerformanceDxe::.*measurements\\s*:.*|->\\s*\\S.*=\\s*\\d+\\s*ms\\b|Total\\s+\\S.*=\\s*\\d+\\s*ms\\b"
    },
    {
      "name": "boot-milestone",
      "level": "boot",
      "pattern": "UEFI\\s+(?:Start|End)\\s+\\[\\s*\\d+\\s*\\]|EBS\\s+completed\\s+successfully"
    },
    {
      "name": "membucket-header",
      "level": "membucket",
      "pattern": "Memory\\s+Previous\\s+Current\\s+Minimum\\s+Next"
    }
  ]
}
